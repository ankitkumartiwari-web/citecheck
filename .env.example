# Copy this file to ".env" and fill in your key.
#   copy .env.example .env   (Windows)
#   cp .env.example .env      (macOS/Linux)

# Get FREE keys at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional 2nd key for load balancing (round-robin + failover, doubles free quota)
# OPENROUTER_API_KEY_2=sk-or-v1-your-second-key-here
# ...or a comma-separated list instead:
# OPENROUTER_API_KEYS=sk-or-v1-key-one,sk-or-v1-key-two

# Optional: override the model (defaults to meta-llama/llama-3.3-70b-instruct:free)
# Free options (note the ":free" suffix):
#   meta-llama/llama-3.3-70b-instruct:free
#   deepseek/deepseek-chat-v3-0324:free
#   google/gemini-2.0-flash-exp:free
#   mistralai/mistral-small-3.1-24b-instruct:free
# ANSWER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: override the API base URL (defaults to OpenRouter)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: where uploaded PDFs, ChromaDB, and usage counters are stored.
# Use a persistent disk path in production.
# DATA_DIR=/opt/render/project/src/data
